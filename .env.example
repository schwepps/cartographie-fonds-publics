# ── Supabase (database + API) ─────────────────────────────────
# DEV = local Supabase CLI stack (`make supabase-up`). The values below are the standard,
# PUBLIC local demo defaults — identical on every machine, valid only against 127.0.0.1.
# They are NOT production secrets. Production values live ONLY in GitHub Actions secrets
# (ingestion) — never here. See DEPLOYMENT.md → "Local development" and SECURITY.md.
SUPABASE_URL=http://127.0.0.1:54421
# SERVER-SIDE ONLY (ingestion writes). Never in the frontend. Local demo service-role key
# (re-fetch any time with: supabase status -o env | grep SERVICE_ROLE_KEY):
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
# Direct Postgres connection for migrations + bulk load (ingestion) — local stack:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres
#
# PROD — do NOT put these here. Set them as GitHub Actions secrets (see DEPLOYMENT.md §3):
#   SUPABASE_URL=https://YOUR-PROJECT.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=<prod service-role key — server/CI only>
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# ── Redis (optional: cache heavy RPCs / ingestion coordination) ─
# The compose Redis (`make up`) starts with `--requirepass`, so REDIS_URL must carry the same
# password as REDIS_PASSWORD below — e.g. redis://:yourpassword@localhost:6379/0 — or clients
# get NOAUTH. The no-password form below only works against an auth-less Redis.
REDIS_URL=redis://localhost:6379/0

# ── Local docker-compose Redis only (required by docker-compose.yml) ──
# Set a strong value; the compose file refuses to start if this is unset.
REDIS_PASSWORD=

# ── Open data access (no key required for reads) ──────────────
DATAGOUV_API_BASE=https://www.data.gouv.fr/api/1
DATAGOUV_MCP_URL=https://mcp.data.gouv.fr/mcp

# ── Optional credentials (later phases) ───────────────────────
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=
INSEE_API_TOKEN=

# Frontend env lives in packages/web/.env (VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY).
