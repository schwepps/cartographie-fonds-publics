# ── Supabase (database + API) ─────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # SERVER-SIDE ONLY (ingestion writes). Never in the frontend.
# Direct Postgres connection for migrations + bulk load (ingestion):
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# ── Redis (optional: cache heavy RPCs / ingestion coordination) ─
REDIS_URL=redis://localhost:6379/0

# ── Local docker-compose only (required by docker-compose.yml) ──
# Set strong values; the compose file refuses to start if these are unset.
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# ── Open data access (no key required for reads) ──────────────
DATAGOUV_API_BASE=https://www.data.gouv.fr/api/1
DATAGOUV_MCP_URL=https://mcp.data.gouv.fr/mcp

# ── Optional credentials (later phases) ───────────────────────
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=
INSEE_API_TOKEN=

# Frontend env lives in packages/web/.env (VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY).
