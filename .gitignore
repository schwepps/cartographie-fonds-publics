# Python
__pycache__/
*.py[cod]
# Track the uv lockfile for reproducible installs (some users' global gitignore has *.lock)
!uv.lock
.venv/
venv/
.uv/
dist/
build/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Node / web
node_modules/
.next/
.turbo/
packages/web/dist/
*.tsbuildinfo

# Env & secrets
.env
.env.*
!.env.example

# Data — NEVER commit raw snapshots or large binaries
data/snapshots/*
!data/snapshots/.gitkeep
*.parquet
*.duckdb

# OS / editor
.DS_Store
.idea/
.vscode/

# Generated spike output
spikes/**/out/

# Generated resolution reports (the crosswalk under data/crosswalk/ stays tracked)
/out/

# Local agent/workspace tooling (not part of the project)
.conductor/
scripts/conductor-setup.sh
